pipeline {
    agent any

    environment {
        DOCKER_CREDS  = credentials('docker-hub-credentials')
        // APP_SERVER_IP = credentials('app-server-ip')
        IMAGE_NAME    = "jecasan/devops-app"
        IMAGE_TAG     = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Building version: ${env.IMAGE_TAG}"
                echo "Commit: ${env.GIT_COMMIT}"
                sh 'ls -la'
            }
        }

        stage('Run Tests') {
            steps{
                echo 'Running automated tests...'
                dir('app') {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                        pip install -r requirements.txt -q
                        pytest tests/ -v --tb=short
                    '''
                }
            }
            post {
                failure {
                    echo ' Tests failed! Deployment cancelled.'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "Building Docker image ${env.IMAGE_NAME}:${env.IMAGE_TAG}"
                sh "docker build -t ${env.IMAGE_NAME}:${env.IMAGE_TAG} app/"
                sh "docker tag ${env.IMAGE_NAME}:${env.IMAGE_TAG} ${env.IMAGE_NAME}:latest"
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo $DOCKER_CREDS_PSW | docker login -u $DOCKER_CREDS_USR --password-stdin
                    docker push ${IMAGE_NAME}:${IMAGE_TAG}
                    docker push ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Deploy to Application Server') {
            steps {
                echo "Deploying version ${env.IMAGE_TAG} via SSM..."
                sh '''
                    # Get app server instance ID
                    APP_INSTANCE_ID=$(aws ec2 describe-instances \
                        --filters "Name=tag:Name,Values=app-server" \
                        --query "Reservations[0].Instances[0].InstanceId" \
                        --region ap-southeast-2 \
                        --output text)

                    echo "Deploying to instance: $APP_INSTANCE_ID"

                    # Send deployment commands via SSM
                    COMMAND_ID=$(aws ssm send-command \
                        --instance-ids "$APP_INSTANCE_ID" \
                        --document-name "AWS-RunShellScript" \
                        --parameters commands=["
                            docker pull ${IMAGE_NAME}:${IMAGE_TAG},
                            docker stop devops-app 2>/dev/null|| true,
                            docker rm devops-app 2> /dev/null || true,
                            docker run -d --name devops-app --restart=unless-stopped -p 80:5000 -e APP_VERSION-$IMAGE_TAG -e ENV=production $IMAGE_NAME:$IMAGE_TAG,
                            sleep 5,
                            docker ps | grep devops-app
                        "] \
                        --region ap-southeast-2 \
                        --query "Command.CommandId" \
                        --output text)

                    echo "Command ID: $COMMAND_ID"

                    # Wait for command to complete
                    aws ssm wait command-executed \
                        --command-id "$COMMAND_ID" \
                        --instance-id "$APP_INSTANCE_ID" \
                        --region ap-southeast-2

                    # Get the result
                    aws ssm get-command-invocation \
                        --command-id "$COMMAND_ID" \
                        --instance-id "$APP_INSTANCE_ID" \
                        --region ap-southeast-2 \
                        --query "[Status,StandardOutputContent]" \
                        --output text
                '''
                }
            }
        

        stage('Health Check') {
            steps {
                echo 'Waiting for app to be ready...'
                sh 'sleep 16'
                sh """
                    APP_PUBLIC_IP=$(aws ec2 describe-instances \
                        --filters "Name=tag:Name,Values=app-server" \
                        --query "Reservations[0].Instances[0].PublicIpAddress" \
                        --region ap-southeast-2 \
                        --output text)

                    echo "Checking app health at http://$APP_PUBLIC_IP/health"
                    curl -f http://$APP_PUBLIC_IP/health
                    echo "Health check passed! App is running and healthy."
                """
            }
        }

        stage('Cleanup') {
            steps {
                echo 'Removing local image to free disk space...'
                sh "docker rmi ${env.IMAGE_NAME}:${env.IMAGE_TAG} || true"
                sh "docker rmi ${env.IMAGE_NAME}:latest || true"
            }
        }
    }

    post {
        success {
            echo """
            ================================================
            DEPLOYMENT SUCCESSFUL
            Version:  ${IMAGE_TAG}
            App URL:  http://${APP_SERVER_IP}
            Commit:   ${GIT_COMMIT}
            ================================================
            """
        }
        failure {
            echo """
            ================================================
            DEPLOYMENT FAILED
            Build:  ${BUILD_NUMBER}
            Check the console output above for the error
            ================================================
            """
        }
        always {
            cleanWs()
        }
    }
}